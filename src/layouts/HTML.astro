---
import Nav from "../components/Nav.astro";

import { getAlbum } from "../lib/musicData";
import { getColors } from "../lib/musicData";
import { getPalette } from "../lib/colors";
const album = await getAlbum();
const palette = getPalette(await getColors(album));
const { dominant, textColor, secondaryTextColor } = palette;

const { title: pageTitle, description } = Astro.props;

let title = pageTitle
    ? `${pageTitle} / twofortyeight.net`
    : "twofortyeight.net";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png"
        />
        <link rel="manifest" href="/site.webmanifest" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <title>{title}</title>
        <meta name="title" content={title} />
        {description && <meta name="description" content={description} />}
    </head>

    <body
        class="min-h-screen flex flex-col gap-2 justify-center items-center py-24"
    >
        <main class="w-4/5 md:w-2/5">
            <slot />
            <Nav />
        </main>
    </body>

    <script>
        // @ts-ignore
        import listen from "micromorph/nav";
        listen();
    </script>
    <style
        is:global
        define:vars={{
            dominant,
            textColor,
            secondaryTextColor,
            accent: palette.palette[0],
        }}
    >
        @font-face {
            font-family: "PP Neue Montreal";
            src:
                url("/fonts/PP Neue Montreal Thin.woff2") format("woff2"),
                url("/fonts/PP Neue Montreal Thin.woff") format("woff");
            font-weight: 100;
            font-style: normal;
            font-display: swap;
        }

        @font-face {
            font-family: "PP Neue Montreal";
            src:
                url("/fonts/PP Neue Montreal Book.woff2") format("woff2"),
                url("/fonts/PP Neue Montreal Book.woff") format("woff");
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }

        @font-face {
            font-family: "PP Neue Montreal";
            src:
                url("/fonts/PP Neue Montreal Italic.woff2") format("woff2"),
                url("/fonts/PP Neue Montreal Italic.woff") format("woff");
            font-weight: 400;
            font-style: italic;
            font-display: swap;
        }

        @font-face {
            font-family: "PP Neue Montreal";
            src:
                url("/fonts/PP Neue Montreal Medium.woff2") format("woff2"),
                url("/fonts/PP Neue Montreal Medium.woff") format("woff");
            font-weight: 500;
            font-style: normal;
            font-display: swap;
        }

        @font-face {
            font-family: "PP Neue Montreal";
            src:
                url("/fonts/PP Neue Montreal SemiBold italic.woff2")
                    format("woff2"),
                url("/fonts/PP Neue Montreal SemiBold italic.woff")
                    format("woff");
            font-weight: 600;
            font-style: italic;
            font-display: swap;
        }

        @font-face {
            font-family: "PP Neue Montreal";
            src:
                url("/fonts/PP Neue Montreal Bold.woff2") format("woff2"),
                url("/fonts/PP Neue Montreal Bold.woff") format("woff");
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }
        * {
            box-sizing: border-box;
            cursor: default;
        }
        body {
            font-family: "PP Neue Montreal", "Helvetica Neue", sans-serif;
            font-weight: 500;
            background-color: var(--dominant, #e9e7d7);
            color: var(--textColor, black);
            --dominant: var(--dominant, #e9e7d7);
            --textColor: var(--textColor, black);
            --secondaryTextColor: var(--secondaryTextColor, white);
            --accent: var(--accent, blue);
            margin: 0;
        }
        a[data-active="true"],
        a:hover {
            background-color: var(--accent, blue);
            color: var(--secondaryTextColor, white);
            cursor: pointer;
        }
        .link-arrow {
            color: var(--accent, blue);
        }
        a:hover .link-arrow {
            color: var(--secondaryTextColor, white);
        }
        a {
            color: var(--accent, blue);
        }
        a[href^="http"] {
            white-space: nowrap;
            text-wrap: wrap;
        }
        h1 {
            background-color: var(--accent, blue);
            color: var(--secondaryTextColor, white);
            font-size: 1rem;
            margin: 0 -0.125rem;
            padding: 0 0.125rem;
            width: max-content;
            font-weight: 500;
        }
    </style>
</html>
